# Database (NeonDB) — pooled URL for the app, direct URL for migrations
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Redis (optional in dev — seat locking falls back to in-memory when unset)
REDIS_URL=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Payments
STRIPE_SECRET_KEY=
PAYMONGO_SECRET_KEY=

# Storage
CLOUDINARY_URL=
